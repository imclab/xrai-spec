# Cloudflare Pages redirect rules for xrai.dev
# https://developers.cloudflare.com/pages/platform/redirects/
#
# Format: <from> <to> <status>
# Status codes: 301 permanent, 302 temporary, 200 rewrite (proxy).

# Canonical shortcut paths
/spec      /SPEC.md            302
/manifesto /MANIFESTO.md       302
/faq       /FAQ.md             302
/changelog /CHANGELOG.md       302
/contribute /CONTRIBUTING.md   302
/rfcs/latest /rfcs/            302

# GitHub org (launch window — canonical repo URL)
/repo      https://github.com/imclab/xra1 302
/github    https://github.com/imclab/xra1 302

# Citation: GitHub-compatible path
/cite      /CITATION.cff       302

# Implementation surfaces
/threejs   /runtimes/threejs/  302
/adapter   /runtimes/threejs/  302
/mcp       /mcp-server/        302

# Old v0 draft paths (if any external blog linked them) → canonical
/v1        /SPEC.md            301
/vision    /VISION.md          302

# Default 404 — serve human-readable 404.html (if/when we add one)
# /*       /404.html           404
