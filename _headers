# Cloudflare Pages headers config for xrai.dev
# https://developers.cloudflare.com/pages/platform/headers/
#
# Security: CSP + HSTS + frame protection (no iframe embedding).
# Cache: aggressive on static fixtures, conservative on docs (updated weekly).
# CORS: allow same-origin; scripts/crawlers can still fetch specs + schemas.

/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: accelerometer=(), camera=(self), geolocation=(), gyroscope=(self), microphone=(self), payment=()
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload

/examples/*
  Cache-Control: public, max-age=604800, immutable
  Content-Type: application/json
  Access-Control-Allow-Origin: *

/runtimes/_conformance/results/*
  Cache-Control: public, max-age=3600
  Access-Control-Allow-Origin: *

/*.json
  Content-Type: application/vnd.xrai+json
  Access-Control-Allow-Origin: *

/*.md
  Content-Type: text/markdown; charset=utf-8
  Cache-Control: public, max-age=86400

/SPEC.md
  Cache-Control: public, max-age=3600
  Access-Control-Allow-Origin: *

/CITATION.cff
  Cache-Control: public, max-age=86400
  Content-Type: text/yaml; charset=utf-8
  Access-Control-Allow-Origin: *
